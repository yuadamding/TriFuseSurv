# Meaningful 2x H100 80GB search for the recommended contour-aware survival path.
# Uses 4-fold OOF c-index, 20 epochs per fold-training run, and compares more
# orthogonal choices around the current strongest region:
# - time discretization
# - risk horizon
# - shell size
# - teacher forcing schedule
# - localization loss strength
# - multiscale on/off
# - radiomics reliance
# - one larger-capacity check near the 70 GB VRAM range

: "${META_CSV:=OPSCC_preprocessed_128/cohort_preprocessed_stage2.csv}"
: "${RADIOMICS_SOURCE:=cohort_radiomics_patient_wide.csv}"
: "${DEVICE:=cuda:0}"
: "${ENDPOINT:=OS}"
ENDPOINT_LC="$(printf '%s' "$ENDPOINT" | tr '[:upper:]' '[:lower:]')"
: "${SPLITS_DIR:=runs/opscc_splits_${ENDPOINT_LC}_seed1}"
: "${OUT_DIR:=runs/contour_aware_cindex_search_h100_meaningful_${ENDPOINT_LC}}"

if ! declare -p FOLDS >/dev/null 2>&1; then
  FOLDS=(0 1 2 3)
fi

if ! declare -p TRIALS >/dev/null 2>&1; then
  TRIALS=(
    meaningful_base
    meaningful_bw120
    meaningful_bw240
    meaningful_h1095
    meaningful_shell3
    meaningful_shell7
    meaningful_tf0
    meaningful_tf20
    meaningful_locweak
    meaningful_locstrong
    meaningful_nomultiscale
    meaningful_p64
    meaningful_norad
    meaningful_f1792
  )
fi

if ! declare -p WEIGHTS_TO_SCORE >/dev/null 2>&1; then
  WEIGHTS_TO_SCORE=(best ema swa last)
fi
