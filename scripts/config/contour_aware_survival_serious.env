#!/usr/bin/env bash

# Serious contour-aware survival run.
# This is the recommended full workflow:
# preprocess -> prepare survival table -> make splits -> contour-aware survival CV

RUN_PREPROCESS=0
RUN_PREPARE_STAGE2=1
RUN_SPLITS=1
RUN_STAGE2=1

# Preparation. Paths are resolved from the workspace root that contains TriFuseSurv_package.
DICOM_ROOT="OPSCC"
SURV_CSV="opscc_survival_time_event.csv"
PREPROCESS_OUT_ROOT="OPSCC_preprocessed_128"
PREPROCESS_OUT_CSV="cohort_preprocessed.csv"
PREPROCESS_SPACING_X="0.5"
PREPROCESS_SPACING_Y="0.5"
PREPROCESS_SPACING_Z="1"
PREPROCESS_SIZE_D="128"
PREPROCESS_SIZE_H="256"
PREPROCESS_SIZE_W="256"
PREPROCESS_MARGIN_MM="30"
PREPROCESS_HU_MIN="-1000"
PREPROCESS_HU_MAX="1000"
PREPROCESS_RECURSIVE=0
PREPROCESS_EXTRA_ARGS=()

# Survival tabular merge
PREPARE_STAGE2_BASE_META_CSV="${PREPROCESS_OUT_ROOT}/cohort_preprocessed.csv"
PREPARE_STAGE2_SURV_CSV="opscc_survival_time_event.csv"
PREPARE_STAGE2_CLIN_CSV="clinical_covariate.csv"
PREPARE_STAGE2_RADIO_CSV="cohort_radiomics_patient_wide.csv"
PREPARE_STAGE2_OUT_DIR="${PREPROCESS_OUT_ROOT}"
PREPARE_STAGE2_OUT_CSV="cohort_preprocessed_stage2.csv"
PREPARE_STAGE2_EXTRA_ARGS=()

# Primary endpoint for reporting, splits, and output naming.
PRIMARY_ENDPOINT="${PRIMARY_ENDPOINT:-OS}"
PRIMARY_ENDPOINT_LC="$(printf '%s' "$PRIMARY_ENDPOINT" | tr '[:upper:]' '[:lower:]')"

# Split generation
SPLITS_META_CSV="${PREPARE_STAGE2_OUT_DIR}/${PREPARE_STAGE2_OUT_CSV}"
SPLITS_QC_REPORT=""
SPLITS_QC_POLICY="none"
SPLITS_QC_DROP_AIR_GT="0"
SPLITS_ENDPOINT="${SPLITS_ENDPOINT:-$PRIMARY_ENDPOINT}"
SPLITS_ENDPOINT_LC="$(printf '%s' "$SPLITS_ENDPOINT" | tr '[:upper:]' '[:lower:]')"
SPLITS_CV_FOLDS="4"
SPLITS_VAL_FRAC="0.2"
SPLITS_SEED="1"
SPLITS_OUT_DIR="runs/opscc_splits_${SPLITS_ENDPOINT_LC}_seed${SPLITS_SEED}"
SPLITS_EXTRA_ARGS=()

# Contour-aware survival
STAGE2_META_CSV="${PREPARE_STAGE2_OUT_DIR}/${PREPARE_STAGE2_OUT_CSV}"
STAGE2_SPLITS_DIR="${SPLITS_OUT_DIR}"
STAGE2_RADIOMICS_SOURCE="${PREPARE_STAGE2_RADIO_CSV}"
STAGE2_USE_LORA=0
STAGE2_USE_RESUME=1
STAGE2_OUT_DIR="runs/contour_aware_survival_serious_${PRIMARY_ENDPOINT_LC}"
STAGE2_EXP_PREFIX="contour_aware_${PRIMARY_ENDPOINT_LC}"
STAGE2_FOLDS=(0 1 2 3)
STAGE2_GPU_IDS=()
STAGE2_DEVICE="cuda:0"
STAGE2_EPOCHS="60"
STAGE2_BATCH_SIZE="1"
STAGE2_WORKERS="2"
STAGE2_DEBUG_MAX_TRAIN="-1"
STAGE2_DEBUG_MAX_VAL="-1"
STAGE2_DEBUG_MAX_TEST="-1"
STAGE2_EXTRA_ARGS=(--report_metric c_index)

# Optional contour-aware encoder warm-start.
# Leave blank for direct survival-first training.
CONTOUR_WARMSTART_CKPT=""
CONTOUR_WARMSTART_DIR=""
CONTOUR_WARMSTART_NAME="best.pt"
